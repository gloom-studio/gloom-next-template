# Better Auth Configuration
BETTER_AUTH_SECRET= # use openssl rand -hex 32
BETTER_AUTH_URL=http://localhost:3000 # your base url
# Client-side Better Auth base URL (browser). Often same as BETTER_AUTH_URL in dev.
NEXT_PUBLIC_BETTER_AUTH_URL=http://localhost:3000

# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/database

# Playwright / E2E (optional overrides)
# PLAYWRIGHT_BASE_URL=http://localhost:3000
# E2E_USER_EMAIL=e2e-user@test.local
# E2E_USER_PASSWORD=E2e_pass_1!
# E2E_USER_NAME=E2E User